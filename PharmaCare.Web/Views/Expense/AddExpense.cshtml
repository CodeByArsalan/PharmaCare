@model PharmaCare.Domain.Entities.Finance.Expense
@{
    ViewData["Title"] = "Record New Expense";
}

<!-- Page Header -->
<div class="page-header">
    <h4 class="page-title">
        <i class="fas fa-plus-circle"></i>
        Record New Expense
    </h4>
    <a asp-action="ExpensesIndex" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="AddExpense" method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Expense Category <span class="text-danger">*</span></label>
                    <select asp-for="ExpenseCategory_ID" asp-items="ViewBag.Categories" class="form-select" id="categorySelect" required>
                        <option value="">-- Select Category --</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Expense Date <span class="text-danger">*</span></label>
                    <input asp-for="ExpenseDate" type="date" class="form-control" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Amount (PKR) <span class="text-danger">*</span></label>
                    <input asp-for="Amount" type="number" step="0.01" min="0.01" class="form-control" placeholder="0.00" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Source Account (Cash/Bank) <span class="text-danger">*</span></label>
                    <select asp-for="SourceAccount_ID" asp-items="ViewBag.SourceAccounts" class="form-select" required>
                        <option value="">-- Select Source --</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Expense Account <span class="text-danger">*</span></label>
                    <select asp-for="ExpenseAccount_ID" asp-items="ViewBag.ExpenseAccounts" class="form-select" id="expenseAccountSelect" required>
                        <option value="">-- Select Account --</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Vendor Name</label>
                    <input asp-for="VendorName" class="form-control" placeholder="e.g., Electric Company" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Reference</label>
                    <input asp-for="Reference" class="form-control" placeholder="e.g., Bill No, Receipt No" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="2" placeholder="Brief description of the expense"></textarea>
                </div>
            </div>

            <div asp-validation-summary="All" class="text-danger mt-3"></div>

            <div class="text-end mt-4">
                <a asp-action="ExpensesIndex" class="btn btn-outline-secondary me-2">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Save Expense
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-fill expense account when category changes
        document.getElementById('categorySelect').addEventListener('change', function () {
            const categoryId = this.value;
            if (!categoryId) return;

            fetch(`/Expense/GetCategoryDefaults?categoryId=${categoryId}`)
                .then(r => r.json())
                .then(data => {
                    if (data.defaultExpenseAccountId) {
                        document.getElementById('expenseAccountSelect').value = data.defaultExpenseAccountId;
                    }
                });
        });
    </script>
}
