@model PharmaCare.Domain.Entities.Transactions.Voucher
@using PharmaCare.Web.Utilities
@{
    ViewData["Title"] = "Journal Voucher Details";
    var isReversed = Model.IsReversed;
}

<!-- Page Header -->
<div class="page-header">
    <h4 class="page-title">
        <i class="fas fa-file-alt"></i>
        Journal Voucher Details
    </h4>
    <a asp-action="JournalVoucherIndex" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<!-- Status Banner -->
@if (isReversed)
{
    <div class="alert alert-danger d-flex align-items-center mb-4">
        <i class="fas fa-ban me-2 fs-5"></i>
        <div>
            <strong>This voucher has been reversed.</strong>
            @if (!string.IsNullOrEmpty(Model.VoidReason))
            {
                <br /><small>Reason: @Model.VoidReason</small>
            }
        </div>
    </div>
}

<div class="row g-4">
    <!-- Voucher Header -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Voucher Information</h6>
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr>
                        <td class="text-muted" style="width:40%">Voucher No</td>
                        <td><code class="fs-6">@Model.VoucherNo</code></td>
                    </tr>
                    <tr>
                        <td class="text-muted">Voucher Type</td>
                        <td>@(Model.VoucherType?.Name ?? "Journal Voucher")</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Date</td>
                        <td>@Model.VoucherDate.ToString("dd MMM yyyy")</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Status</td>
                        <td>
                            @if (isReversed)
                            {
                                <span class="badge bg-danger">Reversed</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@Model.Status</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted">Narration</td>
                        <td>@(Model.Narration ?? "—")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <!-- Total Summary -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="mb-0"><i class="fas fa-calculator me-2"></i>Summary</h6>
            </div>
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="row text-center">
                    <div class="col-6">
                        <div class="text-muted mb-1">Total Debit</div>
                        <div class="fs-4 fw-bold text-success">PKR @Model.TotalDebit.ToString("N2")</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted mb-1">Total Credit</div>
                        <div class="fs-4 fw-bold text-primary">PKR @Model.TotalCredit.ToString("N2")</div>
                    </div>
                </div>
                <hr />
                <div class="text-center">
                    @if (Model.TotalDebit == Model.TotalCredit)
                    {
                        <span class="badge bg-success fs-6"><i class="fas fa-check me-1"></i>Balanced</span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6"><i class="fas fa-times me-1"></i>Unbalanced</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Voucher Details Table -->
<div class="card mt-4">
    <div class="card-header">
        <h6 class="mb-0"><i class="fas fa-list me-2"></i>Journal Entries</h6>
    </div>
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Account</th>
                    <th>Description</th>
                    <th class="text-end">Debit (PKR)</th>
                    <th class="text-end">Credit (PKR)</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.VoucherDetails != null)
                {
                    int row = 1;
                    @foreach (var detail in Model.VoucherDetails)
                    {
                        <tr>
                            <td>@(row++)</td>
                            <td><strong>@(detail.Account?.Name ?? "—")</strong></td>
                            <td>@(detail.Description ?? "—")</td>
                            <td class="text-end @(detail.DebitAmount > 0 ? "fw-bold text-success" : "")">
                                @(detail.DebitAmount > 0 ? detail.DebitAmount.ToString("N2") : "—")
                            </td>
                            <td class="text-end @(detail.CreditAmount > 0 ? "fw-bold text-primary" : "")">
                                @(detail.CreditAmount > 0 ? detail.CreditAmount.ToString("N2") : "—")
                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr class="fw-bold table-secondary">
                    <td colspan="3" class="text-end">Totals:</td>
                    <td class="text-end">@Model.TotalDebit.ToString("N2")</td>
                    <td class="text-end">@Model.TotalCredit.ToString("N2")</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<!-- Reverse Button -->
@if (!isReversed)
{
    <div class="text-end mt-4">
        <button type="button" class="btn btn-danger" id="btnReverse">
            <i class="fas fa-undo me-2"></i>Reverse Voucher
        </button>
    </div>

    <form id="reverseForm" method="post" asp-action="ReverseJournalVoucher" style="display: none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Utility.EncryptId(Model.VoucherID)" />
        <input type="hidden" name="voidReason" id="voidReason" />
    </form>

    @section Scripts {
        <script>
            document.getElementById('btnReverse').addEventListener('click', function () {
                Swal.fire({
                    title: 'Reverse this Voucher?',
                    text: 'A reversal voucher will be created to cancel this one.',
                    input: 'textarea',
                    inputPlaceholder: 'Enter reason for reversal...',
                    inputValidator: (value) => {
                        if (!value) return 'Reversal reason is required.';
                    },
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc2626',
                    cancelButtonColor: '#64748b',
                    confirmButtonText: 'Yes, reverse it!',
                    background: 'var(--bg-card)',
                    color: 'var(--text-primary)'
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById('voidReason').value = result.value;
                        document.getElementById('reverseForm').submit();
                    }
                });
            });
        </script>
    }
}
