@{
    ViewData["Title"] = "Sales Reports";
}

<div class="container-fluid p-0">
    <!-- Premium Header -->
    <div class="report-gateway-header d-flex justify-content-between align-items-center">
        <div>
            <div class="d-flex align-items-center mb-2">
                <a asp-controller="Report" asp-action="Index" class="btn btn-white btn-sm shadow-sm rounded-circle me-3" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-arrow-left text-muted" style="font-size: 0.875rem;"></i>
                </a>
                <span class="text-primary fw-semibold small text-uppercase tracking-wider">Report Center</span>
            </div>
            <h2 class="report-category-title mb-1">Sales Reports</h2>
            <p class="text-muted mb-0">Monitor your revenue, analyze customer behavior, and track sales performance.</p>
        </div>
        <div class="d-none d-md-block">
            <i class="fas fa-chart-pie fa-4x text-primary opacity-10"></i>
        </div>
    </div>

    <!-- Report Grid -->
    <div class="report-grid">
        <!-- Daily Sales Summary -->
        <a asp-action="DailySalesSummary" class="premium-report-card">
            <div class="report-card-icon icon-blue">
                <i class="fas fa-calendar-day"></i>
            </div>
            <div class="report-card-content">
                <h6>Daily Sales Summary</h6>
                <p>Get a snapshot of today's sales performance including charts, category totals, and payment methods.</p>
            </div>
            <div class="report-card-footer">
                <span>View Summary</span>
                <i class="fas fa-arrow-right ms-2"></i>
            </div>
        </a>

        <!-- Detailed Sales Report -->
        <a asp-action="SalesReport" class="premium-report-card">
            <div class="report-card-icon icon-green">
                <i class="fas fa-file-invoice-dollar"></i>
            </div>
            <div class="report-card-content">
                <h6>Detailed Sales Report</h6>
                <p>Fully filterable list of all sales transactions. Export data by date range, customer, or transaction status.</p>
            </div>
            <div class="report-card-footer">
                <span>Access Report</span>
                <i class="fas fa-arrow-right ms-2"></i>
            </div>
        </a>

        <!-- Sales by Product -->
        <a asp-action="SalesByProduct" class="premium-report-card">
            <div class="report-card-icon icon-indigo">
                <i class="fas fa-boxes"></i>
            </div>
            <div class="report-card-content">
                <h6>Sales by Product</h6>
                <p>Identify your top-selling items and analyze product-wise revenue contribution and profit margins.</p>
            </div>
            <div class="report-card-footer">
                <span>Explore Data</span>
                <i class="fas fa-arrow-right ms-2"></i>
            </div>
        </a>

        <!-- Sales by Customer -->
        <a asp-action="SalesByCustomer" class="premium-report-card">
            <div class="report-card-icon icon-purple">
                <i class="fas fa-users"></i>
            </div>
            <div class="report-card-content">
                <h6>Sales by Customer</h6>
                <p>Understand your customer demographics and identify your high-value loyal customer segments.</p>
            </div>
            <div class="report-card-footer">
                <span>Analyze Customers</span>
                <i class="fas fa-arrow-right ms-2"></i>
            </div>
        </a>

        <!-- Customer Balance Summary -->
        <a asp-action="CustomerBalanceSummary" class="premium-report-card">
            <div class="report-card-icon icon-orange">
                <i class="fas fa-user-clock"></i>
            </div>
            <div class="report-card-content">
                <h6>Customer Balance Summary</h6>
                <p>Quick overview of all outstanding balances. Track receivables and manage credit limits effectively.</p>
            </div>
            <div class="report-card-footer">
                <span>Manage Receivables</span>
                <i class="fas fa-arrow-right ms-2"></i>
            </div>
        </a>
    </div>
</div>
