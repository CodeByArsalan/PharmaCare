@{
    ViewData["Title"] = "Sales Reports";
}

<div class="container-fluid p-0">
    <div class="d-flex align-items-center mb-4">
        <a asp-controller="Report" asp-action="Index" class="btn btn-outline-secondary me-3">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h3 class="mb-0">Sales Reports</h3>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0"><i class="fas fa-calendar-day me-2 text-primary"></i> Daily Reports</h5>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <a asp-action="DailySalesSummary" class="list-group-item list-group-item-action py-3 px-0">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">Daily Sales Summary</h6>
                                    <p class="text-muted small mb-0">Today's sales snapshot with charts and totals.</p>
                                </div>
                                <i class="fas fa-chevron-right text-muted"></i>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0"><i class="fas fa-file-invoice-dollar me-2 text-success"></i> Transactional Reports</h5>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <a asp-action="SalesReport" class="list-group-item list-group-item-action py-3 px-0">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">Detailed Sales Report</h6>
                                    <p class="text-muted small mb-0">List of all sales transactions within a date range.</p>
                                </div>
                                <i class="fas fa-chevron-right text-muted"></i>
                            </div>
                        </a>
                        <a asp-action="CustomerBalanceSummary" class="list-group-item list-group-item-action py-3 px-0">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">Customer Balance Summary</h6>
                                    <p class="text-muted small mb-0">Current outstanding balances for all customers.</p>
                                </div>
                                <i class="fas fa-chevron-right text-muted"></i>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0"><i class="fas fa-boxes me-2 text-info"></i> Analytical Reports</h5>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <a asp-action="SalesByProduct" class="list-group-item list-group-item-action py-3 px-0">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">Sales by Product</h6>
                                    <p class="text-muted small mb-0">Product-wise revenue and profit analysis.</p>
                                </div>
                                <i class="fas fa-chevron-right text-muted"></i>
                            </div>
                        </a>
                        <a asp-action="SalesByCustomer" class="list-group-item list-group-item-action py-3 px-0">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">Sales by Customer</h6>
                                    <p class="text-muted small mb-0">Revenue contribution per customer analysis.</p>
                                </div>
                                <i class="fas fa-chevron-right text-muted"></i>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
