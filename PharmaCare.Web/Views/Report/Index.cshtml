@{
    ViewData["Title"] = "Reports Dashboard";
}

<div class="container-fluid p-0">
    <!-- Premium Global Header -->
    <div class="report-gateway-header d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%); border: none;">
        <div>
            <div class="d-flex align-items-center mb-2">
                <span class="badge bg-primary-soft text-primary px-3 py-2 rounded-pill fw-bold text-uppercase tracking-wider shadow-sm" style="font-size: 0.7rem; background: rgba(14, 165, 233, 0.1); border: 1px solid rgba(14, 165, 233, 0.2);">Analytics Hub</span>
            </div>
            <h2 class="text-white fw-bold mb-1" style="letter-spacing: -0.03em;">Executive Reports Dashboard</h2>
            <p class="text-slate-300 mb-0 opacity-75" style="color: #cbd5e1;">Comprehensive business intelligence and financial insights at your fingertips.</p>
        </div>
        <div class="d-none d-lg-block">
            <div class="d-flex gap-3">
                <div class="text-end text-white opacity-50">
                    <small class="d-block text-uppercase fw-bold" style="font-size: 0.65rem;">System Status</small>
                    <span class="fw-semibold">All Systems Normal</span>
                </div>
                <div class="bg-success rounded-circle mt-1 shadow-lg shadow-success/20" style="width: 12px; height: 12px; border: 2px solid rgba(255,255,255,0.2);"></div>
            </div>
        </div>
    </div>

    <!-- Category Gateway Grid -->
    <div class="report-grid">
        <!-- Sales Category -->
        <div class="premium-report-card" style="height: auto; min-height: 280px;">
            <div>
                <div class="report-card-icon icon-blue">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <div class="report-card-content">
                    <h5 class="fw-bold mb-2">Sales Analytics</h5>
                    <p class="mb-4">Monitor revenue streams, customer acquisition, and product performance trends.</p>
                    
                    <div class="quick-links mb-4">
                        <small class="text-uppercase fw-bold text-muted d-block mb-2" style="font-size: 0.7rem;">Quick Access</small>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <a asp-controller="SalesReport" asp-action="DailySalesSummary" class="text-decoration-none text-slate-600 hover-primary d-flex align-items-center" style="font-size: 0.9rem; color: #475569;">
                                    <i class="fas fa-circle me-2 opacity-25" style="font-size: 0.4rem;"></i> Daily Summary
                                </a>
                            </li>
                            <li class="mb-2">
                                <a asp-controller="SalesReport" asp-action="SalesReport" class="text-decoration-none text-slate-600 hover-primary d-flex align-items-center" style="font-size: 0.9rem; color: #475569;">
                                    <i class="fas fa-circle me-2 opacity-25" style="font-size: 0.4rem;"></i> Detailed Sales
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <a asp-controller="SalesReport" asp-action="SalesReportIndex" class="btn btn-primary w-100 rounded-pill fw-bold shadow-sm">
                Open Sales Hub <i class="fas fa-arrow-right ms-2 mt-1" style="font-size: 0.8rem;"></i>
            </a>
        </div>

        <!-- Purchase Category -->
        <div class="premium-report-card" style="height: auto; min-height: 280px;">
            <div>
                <div class="report-card-icon icon-green">
                    <i class="fas fa-truck"></i>
                </div>
                <div class="report-card-content">
                    <h5 class="fw-bold mb-2">Procurement Hub</h5>
                    <p class="mb-4">Track vendor performance, manage purchase orders, and analyze supply chain costs.</p>
                    
                    <div class="quick-links mb-4">
                        <small class="text-uppercase fw-bold text-muted d-block mb-2" style="font-size: 0.7rem;">Quick Access</small>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <a asp-controller="PurchaseReport" asp-action="PurchaseReport" class="text-decoration-none text-slate-600 hover-primary d-flex align-items-center" style="font-size: 0.9rem; color: #475569;">
                                    <i class="fas fa-circle me-2 opacity-25" style="font-size: 0.4rem;"></i> Purchase History
                                </a>
                            </li>
                            <li class="mb-2">
                                <a asp-controller="PurchaseReport" asp-action="PurchaseBySupplier" class="text-decoration-none text-slate-600 hover-primary d-flex align-items-center" style="font-size: 0.9rem; color: #475569;">
                                    <i class="fas fa-circle me-2 opacity-25" style="font-size: 0.4rem;"></i> Supplier Audit
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <a asp-controller="PurchaseReport" asp-action="PurchaseReportIndex" class="btn btn-success w-100 rounded-pill fw-bold shadow-sm">
                Open Purchase Hub <i class="fas fa-arrow-right ms-2 mt-1" style="font-size: 0.8rem;"></i>
            </a>
        </div>

        <!-- Inventory Category -->
        <div class="premium-report-card" style="height: auto; min-height: 280px;">
            <div>
                <div class="report-card-icon icon-indigo">
                    <i class="fas fa-warehouse"></i>
                </div>
                <div class="report-card-content">
                    <h5 class="fw-bold mb-2">Inventory Insights</h5>
                    <p class="mb-4">Real-time stock tracking, movement analysis, and automated low-stock forecasting.</p>
                    
                    <div class="quick-links mb-4">
                        <small class="text-uppercase fw-bold text-muted d-block mb-2" style="font-size: 0.7rem;">Quick Access</small>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <a asp-controller="InventoryReport" asp-action="CurrentStock" class="text-decoration-none text-slate-600 hover-primary d-flex align-items-center" style="font-size: 0.9rem; color: #475569;">
                                    <i class="fas fa-circle me-2 opacity-25" style="font-size: 0.4rem;"></i> Stock Valuation
                                </a>
                            </li>
                            <li class="mb-2">
                                <a asp-controller="InventoryReport" asp-action="LowStock" class="text-decoration-none text-slate-600 hover-primary d-flex align-items-center" style="font-size: 0.9rem; color: #475569;">
                                    <i class="fas fa-circle me-2 opacity-25" style="font-size: 0.4rem;"></i> Reorder Alerts
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <a asp-controller="InventoryReport" asp-action="InventoryReportIndex" class="btn btn-info w-100 rounded-pill fw-bold shadow-sm text-white">
                Open Inventory Hub <i class="fas fa-arrow-right ms-2 mt-1" style="font-size: 0.8rem;"></i>
            </a>
        </div>

        <!-- Financial Category -->
        <div class="premium-report-card" style="height: auto; min-height: 280px;">
            <div>
                <div class="report-card-icon icon-rose">
                    <i class="fas fa-university"></i>
                </div>
                <div class="report-card-content">
                    <h5 class="fw-bold mb-2">Financial Intelligence</h5>
                    <p class="mb-4">Detailed P&L statements, cashflow tracking, and comprehensive accounting ledgers.</p>
                    
                    <div class="quick-links mb-4">
                        <small class="text-uppercase fw-bold text-muted d-block mb-2" style="font-size: 0.7rem;">Quick Access</small>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <a asp-controller="FinancialReport" asp-action="ProfitLoss" class="text-decoration-none text-slate-600 hover-primary d-flex align-items-center" style="font-size: 0.9rem; color: #475569;">
                                    <i class="fas fa-circle me-2 opacity-25" style="font-size: 0.4rem;"></i> Profit & Loss
                                </a>
                            </li>
                            <li class="mb-2">
                                <a asp-controller="FinancialReport" asp-action="CashFlow" class="text-decoration-none text-slate-600 hover-primary d-flex align-items-center" style="font-size: 0.9rem; color: #475569;">
                                    <i class="fas fa-circle me-2 opacity-25" style="font-size: 0.4rem;"></i> Liquidity Tracking
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <a asp-controller="FinancialReport" asp-action="FinancialReportIndex" class="btn btn-danger w-100 rounded-pill fw-bold shadow-sm">
                Open Financial Hub <i class="fas fa-arrow-right ms-2 mt-1" style="font-size: 0.8rem;"></i>
            </a>
        </div>

        <!-- Party Category -->
        <div class="premium-report-card" style="height: auto; min-height: 280px;">
            <div>
                <div class="report-card-icon icon-purple">
                    <i class="fas fa-user-friends"></i>
                </div>
                <div class="report-card-content">
                    <h5 class="fw-bold mb-2">Relationship Center</h5>
                    <p class="mb-4">Manage customer and supplier statements, track credit aging, and view unified ledgers.</p>
                    
                    <div class="quick-links mb-4">
                        <small class="text-uppercase fw-bold text-muted d-block mb-2" style="font-size: 0.7rem;">Quick Access</small>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <a asp-controller="PartyReport" asp-action="CustomerLedger" class="text-decoration-none text-slate-600 hover-primary d-flex align-items-center" style="font-size: 0.9rem; color: #475569;">
                                    <i class="fas fa-circle me-2 opacity-25" style="font-size: 0.4rem;"></i> Customer Ledgers
                                </a>
                            </li>
                            <li class="mb-2">
                                <a asp-controller="PartyReport" asp-action="SupplierLedger" class="text-decoration-none text-slate-600 hover-primary d-flex align-items-center" style="font-size: 0.9rem; color: #475569;">
                                    <i class="fas fa-circle me-2 opacity-25" style="font-size: 0.4rem;"></i> Supplier Audit
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <a asp-controller="PartyReport" asp-action="PartyReportIndex" class="btn btn-secondary w-100 rounded-pill fw-bold shadow-sm" style="background: #475569; border: none;">
                Open Relationship Hub <i class="fas fa-arrow-right ms-2 mt-1" style="font-size: 0.8rem;"></i>
            </a>
        </div>
    </div>
</div>

<style>
    .hover-primary:hover { color: var(--pharma-primary) !important; }
    .bg-primary-soft { background: rgba(14, 165, 233, 0.1); }
</style>
