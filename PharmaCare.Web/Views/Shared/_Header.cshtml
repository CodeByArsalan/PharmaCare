@using PharmaCare.Application.Interfaces
@inject ISessionService SessionService

@{
    var currentUser = SessionService.GetCurrentUser();
    var userName = currentUser?.FullName ?? "User";
}

<header class="header">
    <div class="header-left d-flex align-items-center">
        <button class="sidebar-toggle" id="sidebarToggle">
            <i class="fas fa-bars"></i>
        </button>
        <div class="header-breadcrumb ms-3 d-none d-md-flex align-items-center text-muted animate-on-load">
            <i class="fas fa-home me-2"></i> 
            <span class="mx-2">/</span> 
            <span class="fw-medium" style="color: var(--text-primary);">@ViewData["Title"]</span>
        </div>
    </div>
    
    <div class="header-right">
        <!-- Theme Toggle Button -->
        <button class="theme-toggle-btn" id="themeToggle" title="Toggle Theme">
            <i class="fas fa-sun" id="themeIconLight"></i>
            <i class="fas fa-moon" id="themeIconDark"></i>
        </button>
        
        <div class="dropdown">
            <button class="user-menu-btn dropdown-toggle" type="button" id="userMenuDropdown" 
                    data-bs-toggle="dropdown" aria-expanded="false">
                <div class="avatar-circle">
                    @(string.IsNullOrEmpty(userName) ? "U" : userName.Substring(0, 1).ToUpper())
                </div>
                <span>@userName</span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuDropdown">
                <li>
                    <a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">
                        <i class="fas fa-key me-2"></i> Change Password
                    </a>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post" id="headerLogoutForm">
                        <button type="submit" class="dropdown-item text-danger">
                            <i class="fas fa-sign-out-alt me-2"></i> Logout
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
</header>


