@model PharmaCare.Domain.Entities.Transactions.StockMain
@using PharmaCare.Web.Utilities
@{
    ViewData["Title"] = "Edit Purchase (GRN)";
}

<!-- Page Header -->
<div class="page-header">
    <h4 class="page-title">
        <i class="fas fa-edit"></i>
        Edit Purchase (GRN) - @Model.TransactionNo
    </h4>
    <a asp-action="PurchasesIndex" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="EditPurchase" method="post" id="purchaseForm">
            <input type="hidden" name="StockMainID" value="@Model.StockMainID" />

            <!-- Header Section -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <label class="form-label">Supplier <span class="text-danger">*</span></label>
                    <select name="Party_ID" asp-items="ViewBag.Suppliers" class="form-select" required>
                        <option value="">-- Select Supplier --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Date <span class="text-danger">*</span></label>
                    <input name="TransactionDate" type="date" class="form-control" 
                           value="@Model.TransactionDate.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Reference PO</label>
                    <input type="text" class="form-control" 
                           value="@(Model.ReferenceStockMain?.TransactionNo ?? "Direct Purchase")" disabled
                           style="background-color: var(--bg-elevated, #1e293b); color: var(--text-primary, #f1f5f9); opacity: 0.7;" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Remarks</label>
                    <input name="Remarks" class="form-control" value="@Model.Remarks" placeholder="Optional remarks" />
                </div>
            </div>

            <!-- Line Items Section -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-list me-2"></i>Line Items</h6>
                    <button type="button" class="btn btn-sm btn-primary" id="addLineBtn">
                        <i class="fas fa-plus me-1"></i>Add Item
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered mb-0">
                            <thead style="background-color: var(--bg-card); color: var(--text-primary);">
                                <tr>
                                    <th style="width: 50px;">#</th>
                                    <th style="min-width: 250px;">Product <span class="text-danger">*</span></th>
                                    <th style="width: 120px;">Boxes Recv <span class="text-danger">*</span></th>
                                    <th style="width: 140px;">Box Cost <span class="text-danger">*</span></th>
                                    <th style="width: 140px;">Line Total</th>
                                    <th style="width: 60px;"></th>
                                </tr>
                            </thead>
                            <tbody id="lineItemsBody">
                            </tbody>
                            <tfoot>
                                <tr style="background-color: var(--bg-elevated); color: var(--text-primary);">
                                    <td colspan="4" class="text-end"><strong>Sub Total:</strong></td>
                                    <td class="text-end"><strong id="subTotalDisplay">0.00</strong></td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Totals Section -->
            <div class="row g-3 mb-4">
                <div class="col-md-4 offset-md-8">
                    <div class="card border-success">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold" style="color: var(--text-primary);">Total Amount:</span>
                                <span class="fs-4 fw-bold" id="totalAmountDisplay" style="color: #4ade80;">0.00</span>
                            </div>
                            <input type="hidden" name="SubTotal" id="subTotal" />
                            <input type="hidden" name="DiscountPercent" value="0" />
                            <input type="hidden" name="DiscountAmount" value="0" />
                            <input type="hidden" name="PaidAmount" value="0" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-end">
                <a asp-action="PurchasesIndex" class="btn btn-outline-secondary me-2">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Update Purchase
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        let products = [];
        let rowIndex = 0;

        // Existing details from the GRN being edited
        const existingDetails = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.StockDetails.Select(d => new {
                productId = d.Product_ID,
                quantity = d.Quantity,
                costPrice = d.CostPrice,
                lineTotal = d.LineTotal
            })));

        document.addEventListener('DOMContentLoaded', async function() {
            const response = await fetch('@Url.Action("GetProducts")');
            products = await response.json();

            // Load existing line items
            if (existingDetails.length > 0) {
                existingDetails.forEach(d => addLineItem(d));
            } else {
                addLineItem();
            }
            calculateTotals();
        });

        document.getElementById('addLineBtn').addEventListener('click', function() { addLineItem(); });

        function addLineItem(detail = null) {
            const tbody = document.getElementById('lineItemsBody');
            const row = document.createElement('tr');
            
            let productOptions = '<option value="">-- Select Product --</option>';
            let unitsInPack = 1;
            let displayQuantity = 1;
            let displayCostPrice = 0;
            
            if (detail) {
                const prod = products.find(p => p.id == detail.productId);
                if (prod) {
                    unitsInPack = prod.unitsInPack || 1;
                }
                displayQuantity = detail.quantity / unitsInPack;
                displayCostPrice = detail.costPrice * unitsInPack;
            }

            products.forEach(p => {
                const selected = detail && detail.productId === p.id ? 'selected' : '';
                productOptions += `<option value="${p.id}" data-cost="${p.boxPrice}" data-units="${p.unitsInPack}" ${selected}>${p.name}</option>`;
            });

            const quantity = detail ? detail.quantity : 1;
            const costPrice = detail ? detail.costPrice : 0;
            const lineTotal = detail ? detail.lineTotal : 0;

            row.innerHTML = `
                <td class="align-middle">${rowIndex + 1}</td>
                <td>
                    <select name="StockDetails[${rowIndex}].Product_ID" class="form-select product-select" required>
                        ${productOptions}
                    </select>
                </td>
                <td>
                    <input type="number" class="form-control box-quantity-input" step="0.0001" min="0.0001" value="${displayQuantity}" required />
                    <input type="hidden" name="StockDetails[${rowIndex}].Quantity" class="quantity-input" value="${quantity}" />
                </td>
                <td>
                    <input type="number" class="form-control box-cost-input" step="0.01" min="0" value="${displayCostPrice}" required />
                    <input type="hidden" name="StockDetails[${rowIndex}].CostPrice" class="cost-input" value="${costPrice}" />
                    <input type="hidden" name="StockDetails[${rowIndex}].UnitPrice" class="unit-price-input" value="${costPrice}" />
                </td>
                <td>
                    <input type="number" name="StockDetails[${rowIndex}].LineTotal" class="form-control line-total" 
                           readonly value="${lineTotal}" />
                    <input type="hidden" name="StockDetails[${rowIndex}].LineCost" class="line-cost" value="${lineTotal}" />
                </td>
                <td class="text-center align-middle">
                    <button type="button" class="btn btn-sm btn-outline-danger remove-row-btn">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            `;

            tbody.appendChild(row);
            
            row.querySelector('.product-select').addEventListener('change', onProductChange);
            row.querySelector('.box-quantity-input').addEventListener('input', calculateLineTotal);
            row.querySelector('.box-cost-input').addEventListener('input', calculateLineTotal);
            row.querySelector('.remove-row-btn').addEventListener('click', removeRow);

            rowIndex++;
        }

        function onProductChange(e) {
            const row = e.target.closest('tr');
            const selectedOption = e.target.options[e.target.selectedIndex];
            const boxPrice = parseFloat(selectedOption.dataset.cost) || 0;
            
            row.querySelector('.box-cost-input').value = boxPrice.toFixed(2);
            calculateLineTotal({ target: row.querySelector('.box-quantity-input') });
        }

        function calculateLineTotal(e) {
            const row = e.target.closest('tr');
            
            const productSelect = row.querySelector('.product-select');
            const selectedOption = productSelect.options[productSelect.selectedIndex];
            let unitsInPack = 1;
            if (selectedOption && selectedOption.dataset.units) {
                 unitsInPack = parseInt(selectedOption.dataset.units) || 1;
            }
            
            const boxes = parseFloat(row.querySelector('.box-quantity-input').value) || 0;
            const boxCost = parseFloat(row.querySelector('.box-cost-input').value) || 0;
            const lineTotal = boxes * boxCost;
            
            const internalQuantity = boxes * unitsInPack;
            const internalCostPrice = boxCost / unitsInPack;
            
            row.querySelector('.line-total').value = lineTotal.toFixed(2);
            row.querySelector('.line-cost').value = lineTotal.toFixed(2);
            
            row.querySelector('.quantity-input').value = internalQuantity;
            row.querySelector('.cost-input').value = internalCostPrice.toFixed(2);
            row.querySelector('.unit-price-input').value = internalCostPrice.toFixed(2);
            calculateTotals();
        }

        function removeRow(e) {
            const tbody = document.getElementById('lineItemsBody');
            if (tbody.children.length > 1) {
                e.target.closest('tr').remove();
                renumberRows();
                calculateTotals();
            } else {
                Swal.fire({
                    icon: 'warning',
                    title: 'Cannot Remove',
                    text: 'At least one line item is required.',
                    background: '#1e293b',
                    color: '#f1f5f9'
                });
            }
        }

        function renumberRows() {
            const rows = document.querySelectorAll('#lineItemsBody tr');
            rows.forEach((row, idx) => {
                row.cells[0].textContent = idx + 1;
                row.querySelector('.product-select').name = `StockDetails[${idx}].Product_ID`;
                row.querySelector('.quantity-input').name = `StockDetails[${idx}].Quantity`;
                row.querySelector('.cost-input').name = `StockDetails[${idx}].CostPrice`;
                row.querySelector('.unit-price-input').name = `StockDetails[${idx}].UnitPrice`;
                row.querySelector('.line-total').name = `StockDetails[${idx}].LineTotal`;
                row.querySelector('.line-cost').name = `StockDetails[${idx}].LineCost`;
            });
            rowIndex = rows.length;
        }

        function calculateTotals() {
            const lineTotals = document.querySelectorAll('.line-total');
            let total = 0;
            lineTotals.forEach(input => {
                total += parseFloat(input.value) || 0;
            });

            document.getElementById('subTotalDisplay').textContent = total.toFixed(2);
            document.getElementById('subTotal').value = total.toFixed(2);
            document.getElementById('totalAmountDisplay').textContent = total.toFixed(2);
        }
    </script>
}
