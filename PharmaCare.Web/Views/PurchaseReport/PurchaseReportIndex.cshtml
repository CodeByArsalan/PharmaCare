@{
    ViewData["Title"] = "Purchase Reports";
}

<div class="container-fluid p-0">
    <div class="d-flex align-items-center mb-4">
        <a asp-controller="Report" asp-action="Index" class="btn btn-outline-secondary me-3">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h3 class="mb-0">Purchase Reports</h3>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0"><i class="fas fa-file-invoice me-2 text-primary"></i> Transactional Reports</h5>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <a asp-action="PurchaseReport" class="list-group-item list-group-item-action py-3 px-0">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">Purchase Report</h6>
                                    <p class="text-muted small mb-0">Detailed list of purchases and returns by date range.</p>
                                </div>
                                <i class="fas fa-chevron-right text-muted"></i>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0"><i class="fas fa-industry me-2 text-info"></i> Analytical Reports</h5>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <a asp-action="PurchaseBySupplier" class="list-group-item list-group-item-action py-3 px-0">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">Purchase by Supplier</h6>
                                    <p class="text-muted small mb-0">Detailed spending analysis per supplier.</p>
                                </div>
                                <i class="fas fa-chevron-right text-muted"></i>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
