@{
    ViewData["Title"] = "Purchase Reports";
}

<div class="container-fluid p-0">
    <!-- Premium Header -->
    <div class="report-gateway-header d-flex justify-content-between align-items-center">
        <div>
            <div class="d-flex align-items-center mb-2">
                <a asp-controller="Report" asp-action="Index" class="btn btn-white btn-sm shadow-sm rounded-circle me-3" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-arrow-left text-muted" style="font-size: 0.875rem;"></i>
                </a>
                <span class="text-primary fw-semibold small text-uppercase tracking-wider">Report Center</span>
            </div>
            <h2 class="report-category-title mb-1">Purchase Reports</h2>
            <p class="text-muted mb-0">Track your procurement, manage supplier relationships, and analyze spending patterns.</p>
        </div>
        <div class="d-none d-md-block">
            <i class="fas fa-shopping-cart fa-4x text-primary opacity-10"></i>
        </div>
    </div>

    <!-- Report Grid -->
    <div class="report-grid">
        <!-- Purchase Report -->
        <a asp-action="PurchaseReport" class="premium-report-card">
            <div class="report-card-icon icon-blue">
                <i class="fas fa-file-invoice"></i>
            </div>
            <div class="report-card-content">
                <h6>Purchase Report</h6>
                <p>Detailed list of all purchase transactions and returns. Filter by date, supplier, or transaction status.</p>
            </div>
            <div class="report-card-footer">
                <span>Access Report</span>
                <i class="fas fa-arrow-right ms-2"></i>
            </div>
        </a>

        <!-- Purchase by Supplier -->
        <a asp-action="PurchaseBySupplier" class="premium-report-card">
            <div class="report-card-icon icon-indigo">
                <i class="fas fa-industry"></i>
            </div>
            <div class="report-card-content">
                <h6>Purchase by Supplier</h6>
                <p>Analyze your spending per supplier. Identify your primary vendors and track procurement volumes.</p>
            </div>
            <div class="report-card-footer">
                <span>Explore Data</span>
                <i class="fas fa-arrow-right ms-2"></i>
            </div>
        </a>
    </div>
</div>
