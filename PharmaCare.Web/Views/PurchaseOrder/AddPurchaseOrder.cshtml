@model PharmaCare.Domain.Entities.Transactions.StockMain
@{
    ViewData["Title"] = "Add Purchase Order";
}

<!-- Page Header -->
<div class="page-header">
    <h4 class="page-title">
        <i class="fas fa-plus-circle"></i>
        Add Purchase Order
    </h4>
    <a asp-action="PurchaseOrdersIndex" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="AddPurchaseOrder" method="post" id="purchaseOrderForm">
            <!-- Header Section -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label class="form-label">Supplier <span class="text-danger">*</span></label>
                    <select asp-for="Party_ID" asp-items="ViewBag.Suppliers" class="form-select" required>
                        <option value="">-- Select Supplier --</option>
                    </select>
                    <span asp-validation-for="Party_ID" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Date <span class="text-danger">*</span></label>
                    <input asp-for="TransactionDate" type="date" class="form-control" required />
                    <span asp-validation-for="TransactionDate" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Remarks</label>
                    <input asp-for="Remarks" class="form-control" placeholder="Optional remarks" />
                </div>
            </div>

            <!-- Line Items Section -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-list me-2"></i>Line Items</h6>
                    <button type="button" class="btn btn-sm btn-primary" id="addLineBtn">
                        <i class="fas fa-plus me-1"></i>Add Item
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered mb-0" id="lineItemsTable">
                            <thead style="background-color: var(--bg-card); color: var(--text-primary);">
                                <tr>
                                    <th style="width: 50px;">#</th>
                                    <th style="min-width: 200px;">Product <span class="text-danger">*</span></th>
                                    <th style="width: 150px;">Quantity <span class="text-danger">*</span></th>
                                    <th style="width: 140px;">Unit Price <span class="text-danger">*</span></th>
                                    <th style="width: 140px;">Line Total</th>
                                    <th style="width: 60px;"></th>
                                </tr>
                            </thead>
                            <tbody id="lineItemsBody">
                                <!-- Dynamic rows will be added here -->
                            </tbody>
                            <tfoot>
                                <tr style="background-color: var(--bg-elevated); color: var(--text-primary);">
                                    <td colspan="4" class="text-end"><strong>Sub Total:</strong></td>
                                    <td class="text-end"><strong id="subTotalDisplay">0.00</strong></td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Totals Section -->
            <div class="row g-3 mb-4">
                <div class="col-md-4 offset-md-8">
                    <div class="card border-success">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold" style="color: var(--text-primary);">Total Amount:</span>
                                <span class="fs-4 fw-bold" id="totalAmountDisplay" style="color: #4ade80;">0.00</span>
                            </div>
                            <input type="hidden" asp-for="SubTotal" id="subTotal" />
                            <input type="hidden" asp-for="TotalAmount" id="totalAmount" />
                            <input type="hidden" asp-for="DiscountPercent" value="0" />
                            <input type="hidden" asp-for="DiscountAmount" value="0" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Advance Payment Section (Optional) -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-money-bill-wave me-2"></i>Advance Payment <span class="text-muted small">(Optional)</span></h6>
                </div>
                <div class="card-body" id="paymentSection">
                    <div class="alert alert-info py-2 mb-3">
                        <i class="fas fa-info-circle me-1"></i>
                        Leave amount at <strong>0</strong> to save without payment. If you enter a payment amount, the PO will be <strong>auto-approved</strong> and the advance recorded immediately.
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Payment Amount</label>
                            <div class="input-group">
                                <span class="input-group-text">PKR</span>
                                <input type="number" name="PaidAmount" id="paidAmount" class="form-control" step="0.01" min="0" value="0" onchange="togglePaymentDetails()" />
                            </div>
                            <div class="form-text" id="maxPayableHint">Max: 0.00</div>
                        </div>
                    </div>
                    <div id="paymentDetailsSection" style="display:none;">
                        <div class="row g-3 mt-1">
                            <div class="col-md-4">
                                <label class="form-label">Payment Method <span class="text-danger">*</span></label>
                                <select name="PaymentMethod" id="paymentMethod" class="form-select">
                                    <option value="Cash">Cash</option>
                                    <option value="Bank">Bank Transfer</option>
                                    <option value="Cheque">Cheque</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Account <span class="text-danger">*</span></label>
                                <select name="PaymentAccountId" id="paymentAccount" class="form-select">
                                    <option value="">-- Select Account --</option>
                                </select>
                            </div>
                            <div class="col-md-4" id="chequeNoGroup" style="display: none;">
                                <label class="form-label">Cheque No</label>
                                <input type="text" name="ChequeNo" class="form-control" placeholder="Enter cheque number" />
                            </div>
                            <div class="col-md-4" id="chequeDateGroup" style="display: none;">
                                <label class="form-label">Cheque Date</label>
                                <input type="date" name="ChequeDate" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-end">
                <a asp-action="PurchaseOrdersIndex" class="btn btn-outline-secondary me-2">Cancel</a>
                <button type="submit" class="btn btn-primary" id="submitBtn">
                    <i class="fas fa-save me-2"></i>Save Purchase Order
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        let products = [];
        let rowIndex = 0;

        // Load products on page load
        document.addEventListener('DOMContentLoaded', async function() {
            const response = await fetch('@Url.Action("GetProducts")');
            products = await response.json();
            addLineItem(); // Add initial row
            
            // Handle Enter key on line total to add new row and open product Select2 dropdown
            $(document).on('keydown', '.line-total', function(e) {
                if (e.which === 13) {
                    e.preventDefault();
                    $('#addLineBtn').click();
                    setTimeout(function() {
                        var $sel = $('#lineItemsBody tr:last').find('.product-select');
                        if ($sel.length) { $sel.select2('open'); }
                    }, 150);
                }
            });
        });

        // Add line item button
        document.getElementById('addLineBtn').addEventListener('click', addLineItem);

        function addLineItem() {
            const tbody = document.getElementById('lineItemsBody');
            const row = document.createElement('tr');
            row.id = `row_${rowIndex}`;
            
            let productOptions = '<option value="">-- Select Product --</option>';
            products.forEach(p => {
                productOptions += `<option value="${p.id}" data-cost="${p.costPrice}">${p.name}</option>`;
            });

            row.innerHTML = `
                <td class="align-middle">${rowIndex + 1}</td>
                <td>
                    <select name="StockDetails[${rowIndex}].Product_ID" class="form-select product-select" required>
                        ${productOptions}
                    </select>
                </td>
                <td>
                    <input type="number" name="StockDetails[${rowIndex}].Quantity" class="form-control quantity-input" 
                           step="0.0001" min="0.0001" value="1" required />
                </td>
                <td>
                    <input type="number" name="StockDetails[${rowIndex}].UnitPrice" class="form-control price-input" 
                           step="0.01" min="0" value="0" required />
                    <input type="hidden" name="StockDetails[${rowIndex}].CostPrice" class="cost-price-input" value="0" />
                </td>
                <td>
                    <input type="number" name="StockDetails[${rowIndex}].LineTotal" class="form-control line-total" 
                           readonly value="0" />
                </td>
                <td class="text-center align-middle">
                    <button type="button" class="btn btn-sm btn-outline-danger remove-row-btn">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            `;

            tbody.appendChild(row);

            // Initialize Select2 on the product dropdown
            var $productSelect = $(row.querySelector('.product-select'));
            $productSelect.select2({
                theme: 'bootstrap-5',
                placeholder: '-- Select Product --',
                allowClear: true,
                width: '100%'
            });
            $productSelect.on('change', onProductChange);

            // Add event listeners
            row.querySelector('.quantity-input').addEventListener('input', calculateLineTotal);
            row.querySelector('.price-input').addEventListener('input', calculateLineTotal);
            row.querySelector('.remove-row-btn').addEventListener('click', removeRow);

            rowIndex++;
        }

        function onProductChange(e) {
            const row = e.target.closest('tr');
            const selectedOption = e.target.options[e.target.selectedIndex];
            const costPrice = parseFloat(selectedOption.dataset.cost) || 0;
            
            row.querySelector('.cost-price-input').value = costPrice;
            row.querySelector('.price-input').value = costPrice.toFixed(2);
            calculateLineTotal({ target: row.querySelector('.quantity-input') });
        }

        function calculateLineTotal(e) {
            const row = e.target.closest('tr');
            const quantity = parseFloat(row.querySelector('.quantity-input').value) || 0;
            const unitPrice = parseFloat(row.querySelector('.price-input').value) || 0;
            const lineTotal = quantity * unitPrice;
            
            row.querySelector('.line-total').value = lineTotal.toFixed(2);
            calculateTotals();
        }

        function removeRow(e) {
            const tbody = document.getElementById('lineItemsBody');
            if (tbody.children.length > 1) {
                e.target.closest('tr').remove();
                renumberRows();
                calculateTotals();
            } else {
                Swal.fire({
                    icon: 'warning',
                    title: 'Cannot Remove',
                    text: 'At least one line item is required.',
                    background: '#1e293b',
                    color: '#f1f5f9'
                });
            }
        }

        function renumberRows() {
            const rows = document.querySelectorAll('#lineItemsBody tr');
            rows.forEach((row, idx) => {
                row.cells[0].textContent = idx + 1;
                // Update input names
                row.querySelector('.product-select').name = `StockDetails[${idx}].Product_ID`;
                row.querySelector('.quantity-input').name = `StockDetails[${idx}].Quantity`;
                row.querySelector('.price-input').name = `StockDetails[${idx}].UnitPrice`;
                row.querySelector('.cost-price-input').name = `StockDetails[${idx}].CostPrice`;
                row.querySelector('.line-total').name = `StockDetails[${idx}].LineTotal`;
            });
            rowIndex = rows.length;
        }

        function calculateTotals() {
            const lineTotals = document.querySelectorAll('.line-total');
            let total = 0;
            lineTotals.forEach(input => {
                total += parseFloat(input.value) || 0;
            });

            document.getElementById('subTotalDisplay').textContent = total.toFixed(2);
            document.getElementById('subTotal').value = total.toFixed(2);
            document.getElementById('totalAmountDisplay').textContent = total.toFixed(2);
            document.getElementById('totalAmount').value = total.toFixed(2);

            // Update payment max
            const payAmtEl = document.getElementById('paidAmount');
            if (payAmtEl) {
                payAmtEl.max = total.toFixed(2);
                document.getElementById('maxPayableHint').textContent = 'Max: ' + total.toFixed(2);
                if (parseFloat(payAmtEl.value) > total) {
                    payAmtEl.value = total.toFixed(2);
                }
            }
        }

        // ----- Payment Section (Select2-compatible) -----
        const accountsByTypeUrl = '@Url.Action("GetAccountsByType", "SupplierPayment")';

        function loadAccountsByMethod() {
            const method = $('#paymentMethod').val();
            const isCheque = method === 'Cheque';

            $('#chequeNoGroup').toggle(isCheque);
            $('#chequeDateGroup').toggle(isCheque);

            // Load accounts based on method
            let typeId = 0;
            if (method === 'Cash') typeId = 1;
            else if (method === 'Bank' || method === 'Cheque') typeId = 2;

            if (typeId > 0) {
                $.getJSON(accountsByTypeUrl, { typeId: typeId }, function (data) {
                    var $account = $('#paymentAccount');
                    // Destroy Select2 before rebuilding options
                    if ($account.hasClass('select2-hidden-accessible')) {
                        $account.select2('destroy');
                    }
                    $account.empty().append('<option value="">-- Select Account --</option>');
                    $.each(data, function (i, item) {
                        $account.append('<option value="' + item.id + '">' + item.name + '</option>');
                    });
                    // Reinitialize Select2
                    if (window.PharmaCareSelect2) {
                        window.PharmaCareSelect2.reinit($account[0]);
                    }
                });
            }
        }

        $('#paymentMethod').on('change', loadAccountsByMethod);

        // Toggle payment details based on amount
        function togglePaymentDetails() {
            const amount = parseFloat(document.getElementById('paidAmount').value) || 0;
            const section = document.getElementById('paymentDetailsSection');
            const accountSelect = document.getElementById('paymentAccount');
            if (amount > 0) {
                section.style.display = 'block';
                accountSelect.setAttribute('required', 'required');
                loadAccountsByMethod();
            } else {
                section.style.display = 'none';
                accountSelect.removeAttribute('required');
            }
        }

        // Load initial accounts on page load
        loadAccountsByMethod();
    </script>
}
