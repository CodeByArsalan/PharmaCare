@using PharmaCare.Web.Utilities
@model PharmaCare.Domain.Entities.Finance.Payment
@{
    ViewData["Title"] = "Payment Details";
}

<!-- Page Header -->
<div class="page-header">
    <h4 class="page-title">
        <i class="fas fa-receipt"></i>
        Payment Details - @Model.Reference
        @if (Model.IsVoided)
        {
            <span class="badge bg-danger ms-2">VOIDED</span>
        }
    </h4>
    <a asp-action="PaymentsIndex" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to List
    </a>
</div>

@if (Model.IsVoided)
{
    <div class="card border-danger mb-4">
        <div class="card-header bg-danger text-white">
            <h6 class="mb-0"><i class="fas fa-ban me-2"></i>Void Information</h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <label class="form-label text-muted small">Voided At</label>
                    <p class="mb-0">@Model.VoidedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
                <div class="col-md-8">
                    <label class="form-label text-muted small">Reason</label>
                    <p class="mb-0">@Model.VoidReason</p>
                </div>
            </div>
        </div>
    </div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Payment Information</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-sm table-borderless">
                            <tr>
                                <td class="text-muted w-40pct">Reference:</td>
                                <td><strong>@Model.Reference</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Payment Date:</td>
                                <td>@Model.PaymentDate.ToString("dd/MM/yyyy")</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Supplier:</td>
                                <td>@Model.Party?.Name</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Payment Method:</td>
                                <td>
                                    <span class="badge bg-@(Model.PaymentMethod == "Cash" ? "success" : Model.PaymentMethod == "Bank" ? "primary" : "warning")">
                                        @Model.PaymentMethod
                                    </span>
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-sm table-borderless">
                            <tr>
                                <td class="text-muted w-40pct">Account:</td>
                                <td>@Model.Account?.Name</td>
                            </tr>
                            @if (Model.PaymentMethod == "Cheque")
                            {
                                <tr>
                                    <td class="text-muted">Cheque No:</td>
                                    <td>@Model.ChequeNo</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Cheque Date:</td>
                                    <td>@Model.ChequeDate?.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                            <tr>
                                <td class="text-muted">Purchase Ref:</td>
                                <td>
                                    @if (Model.StockMain != null)
                                    {
                                        if (Model.StockMain.TransactionType?.Code == "GRN")
                                        {
                                            <a asp-controller="Purchase" asp-action="ViewPurchase" asp-route-id="@Model.StockMain.StockMainID.EncryptId()">
                                                @Model.StockMain.TransactionNo
                                            </a>
                                        }
                                        else if (Model.StockMain.TransactionType?.Code == "PO")
                                        {
                                            <a asp-controller="PurchaseOrder" asp-action="ViewPurchaseOrder" asp-route-id="@Model.StockMain.StockMainID.EncryptId()">
                                                @Model.StockMain.TransactionNo
                                            </a>
                                        }
                                        else
                                        {
                                            @Model.StockMain.TransactionNo
                                        }
                                    }
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Remarks))
                {
                    <div class="mt-3">
                        <label class="text-muted">Remarks:</label>
                        <p class="mb-0">@Model.Remarks</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-12 mt-2">
        <div class="card">
            <div class="card-body text-center">
                <h6 class="text-muted mb-2">Payment Amount</h6>
                <h2 class="@(Model.IsVoided ? "text-danger text-decoration-line-through" : "text-success") mb-0">PKR @Model.Amount.ToString("N2")</h2>
            </div>
        </div>
    </div>

    @if (!Model.IsVoided)
    {
        <div class="col-md-12 mt-3">
            <div class="text-end">
                <button type="button" class="btn btn-danger" id="btnVoidPayment">
                    <i class="fas fa-ban me-2"></i>Void Payment
                </button>
            </div>
        </div>
    }
</div>

<!-- Void Confirmation Form -->
<form id="voidForm" method="post" asp-action="VoidPayment" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.PaymentID.EncryptId()" />
    <input type="hidden" name="reason" id="voidReason" />
</form>

@section Scripts {
    <script>
        var voidBtn = document.getElementById('btnVoidPayment');
        if (voidBtn) {
            voidBtn.addEventListener('click', function() {
                Swal.fire({
                    title: 'Void Payment?',
                    html: `
                        <p>Are you sure you want to void payment <strong>@Model.Reference</strong>?</p>
                        <p class="text-danger small">This will reverse the accounting entries and recalculate the transaction balance.</p>
                        <div class="mt-3">
                            <label class="form-label text-start d-block">Reason:</label>
                            <input type="text" id="swalReason" class="form-control" placeholder="Enter void reason" required>
                        </div>
                    `,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc2626',
                    cancelButtonColor: '#64748b',
                    confirmButtonText: 'Yes, void it!',
                    cancelButtonText: 'Cancel',
                    background: '#1e293b',
                    color: '#f1f5f9',
                    preConfirm: () => {
                        const reason = document.getElementById('swalReason').value;
                        if (!reason) {
                            Swal.showValidationMessage('Please enter a reason');
                            return false;
                        }
                        return reason;
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById('voidReason').value = result.value;
                        document.getElementById('voidForm').submit();
                    }
                });
            });
        }
    </script>
}
